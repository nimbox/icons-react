{
  "name": "@nimbox/icons-react",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/icons/components/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js",
      "development": "./src/icons/components/index.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/icons/components/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "rm -rf dist/* && npm run build:icons && npm run build:types && rollup -c",
    "build:types": "tsc -p tsconfig.types.json --emitDeclarationOnly --declaration --outDir dist/types",
    "build:watch": "rm -rf dist/* && npm run build:icons && npm run build:types && rollup -cw",
    "build:watch:yalc": "rm -rf dist/* && npm run build:icons && npm run build:types && rollup -cw -p ./yalc.js",
    "build:icons": "rm -f src/icons/components/*.tsx && cp src/icons/sources/*.svg src/icons/outlines && svgr --config-file icons.svgr.config.js --icon --typescript --silent --out-dir src/icons/components src/icons/outlines",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "porcelain": "git status --porcelain -- || (echo 'Uncommitted changes detected' && exit 1)",
    "preversion": "npm ci && npm run build && npm run porcelain",
    "postversion": "git push origin main --follow-tags"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/@nimbox"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/addon-links": "^10.0.8",
    "@storybook/react-vite": "^10.0.8",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.6",
    "@vitejs/plugin-react": "^5.1.1",
    "execa": "^9.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "rollup": "^4.53.2",
    "rollup-plugin-filesize": "^10.0.0",
    "storybook": "^10.0.8",
    "tailwindcss": "^4.1.17",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  }
}
