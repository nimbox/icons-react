// tsconfig.types.json
{
  "extends": "./tsconfig.app.json",
  "include": ["src"],
  "exclude": [
    "**/*.stories.*",
    "**/*.test.*"
  ],
  "compilerOptions": {

    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist/types",

    // optional but recommended for published libs:
    "types": ["react"],          // avoid pulling every @types/*
    "stripInternal": true,       // drop /** @internal */ from d.ts
    "rootDir": "src"

  }
}
